{
    "name": "voicecommand-electron",
    "version": "1.0.0",
    "main": "dist/main.js",
    "scripts": {
        "dev": "concurrently \"tsc --watch\" \"electron . --dev\"",
        "build": "tsc",
        "build:mac": "npm run build && electron-builder --mac",
        "start": "electron ."
    },
    "dependencies": {
        "electron-store": "^8.1.0",
        "form-data": "^4.0.5",
        "node-fetch": "^2.7.0",
        "node-record-lpcm16": "^1.0.1"
    },
    "devDependencies": {
        "@types/node": "^20.11.19",
        "concurrently": "^9.2.1",
        "electron": "^28.2.3",
        "electron-builder": "^24.13.3",
        "electron-reload": "^2.0.0-alpha.1",
        "typescript": "^5.3.3"
    },
    "build": {
        "appId": "com.voicecommand.app",
        "productName": "VoiceCommand",
        "directories": {
            "output": "dist"
        },
        "mac": {
            "category": "public.app-category.productivity",
            "target": [
                "dmg"
            ],
            "icon": "app/assets/icon.icns"
        },
        "files": [
            "dist/**/*",
            "renderer/**/*",
            "app/**/*"
        ]
    }
}
