# =============================================================================
# VoiceCommand - Production Environment Variables
# Copy this file to .env and fill in your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=production
PORT=3000

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# MongoDB connection string
# For Docker Compose: mongodb://mongo:27017/voicecommand
# For MongoDB Atlas: mongodb+srv://user:password@cluster.mongodb.net/voicecommand
MONGODB_URI=mongodb://mongo:27017/voicecommand

# MongoDB credentials (for Docker Compose)
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=changeme_secure_password

# -----------------------------------------------------------------------------
# Cache & Queue
# -----------------------------------------------------------------------------
# Redis connection string
# For Docker Compose: redis://redis:6379
# For external Redis: redis://user:password@host:port
REDIS_URL=redis://redis:6379

# -----------------------------------------------------------------------------
# AI Services
# -----------------------------------------------------------------------------
# OpenAI API (required for Whisper, GPT)
OPENAI_API_KEY=sk-your-openai-key

# Groq API (optional, for faster inference)
GROQ_API_KEY=gsk-your-groq-key

# Google AI (for Gemini models)
GOOGLE_API_KEY=your-google-api-key

# -----------------------------------------------------------------------------
# Email Service
# -----------------------------------------------------------------------------
# SendGrid API (optional, for notifications)
SENDGRID_API_KEY=SG.your-sendgrid-key

# -----------------------------------------------------------------------------
# Monitoring
# -----------------------------------------------------------------------------
# Sentry DSN (optional, for error tracking)
SENTRY_DSN=https://your-sentry-dsn

# -----------------------------------------------------------------------------
# Puppeteer / Browser
# -----------------------------------------------------------------------------
# These are typically set in Dockerfile, only override if needed
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome
# PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage

# -----------------------------------------------------------------------------
# WhatsApp Web.js
# -----------------------------------------------------------------------------
# Webhook URL for WhatsApp notifications (optional)
# WHATSAPP_WEBHOOK_URL=https://your-domain.com/webhook

# -----------------------------------------------------------------------------
# LinkedIn Automation
# -----------------------------------------------------------------------------
# LinkedIn credentials (use with caution, consider using session files)
# LINKEDIN_EMAIL=your-email@example.com
# LINKEDIN_PASSWORD=your-password

# LinkedIn session cookie encryption key (REQUIRED for session persistence)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes)
LINKEDIN_ENCRYPTION_KEY=your-64-char-hex-key-here

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# JWT Secret (if implementing authentication)
# JWT_SECRET=your-super-secret-jwt-key

# API Key for external integrations
# API_KEY=your-api-key
