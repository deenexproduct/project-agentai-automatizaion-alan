# =============================================================================
# Docker Ignore File - VoiceCommand
# Optimized to minimize build context and image size
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
**/node_modules
**/npm-debug.log
**/yarn-debug.log
**/yarn-error.log
**/package-lock.json
**/yarn.lock

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
**/dist
**/build
**/.next
**/out

# -----------------------------------------------------------------------------
# Environment and secrets
# -----------------------------------------------------------------------------
**/.env
**/.env.*
!**/.env.example
**/*.pem
**/*.key
**/*.crt
**/*.p12
**/*.pfx
**/secrets/
**/credentials/

# -----------------------------------------------------------------------------
# Version control
# -----------------------------------------------------------------------------
**/.git
**/.gitignore
**/.gitattributes
**/.svn
**/.hg

# -----------------------------------------------------------------------------
# IDE and editor files
# -----------------------------------------------------------------------------
**/.idea
**/.vscode
**/*.swp
**/*.swo
**/*.swn
**/*.bak
**/*.tmp
**/.DS_Store
**/*.sublime-*
**/.atom/
**/.eclipse/

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
**/coverage
**/.nyc_output
**/__tests__
**/*.test.ts
**/*.test.js
**/*.spec.ts
**/*.spec.js
**/jest.config.js
**/.jest/
**/cypress/
**/playwright-report/
**/test-results/

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
**/README.md
**/README*
**/CHANGELOG*
**/LICENSE*
**/docs/
**/*.md
!**/AGENTS.md

# -----------------------------------------------------------------------------
# CI/CD
# -----------------------------------------------------------------------------
**/.github
**/.gitlab-ci.yml
**/Jenkinsfile
**/.travis.yml
**/.circleci

# -----------------------------------------------------------------------------
# Docker files (avoid recursion)
# -----------------------------------------------------------------------------
docker/
!docker/nginx/
Dockerfile*
docker-compose*
.dockerignore

# -----------------------------------------------------------------------------
# Project specific - Logs and temporary files
# -----------------------------------------------------------------------------
**/logs
**/*.log
**/tmp
**/temp
**/uploads/*
!**/uploads/.gitkeep
**/wa-session/*
!**/wa-session/.gitkeep
**/linkedin-session/*
!**/linkedin-session/.gitkeep
**/data/*
!**/data/.gitkeep

# -----------------------------------------------------------------------------
# Electron specific (not needed for server)
# -----------------------------------------------------------------------------
/electron/
/electron-builder.yml

# -----------------------------------------------------------------------------
# Chrome extension (not needed for server)
# -----------------------------------------------------------------------------
/chrome-extension/

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
**/.eslintcache
**/.prettiercache
**/tsconfig.tsbuildinfo
**/*.tsbuildinfo
**/.nvmrc
**/.editorconfig
**/.prettierrc
**/.eslintrc
**/.eslintignore
**/CODEOWNERS
**/CONTRIBUTING.md
