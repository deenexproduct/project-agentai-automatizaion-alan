# =============================================================================
# VoiceCommand - Multi-Stage Optimized Dockerfile
# Production-ready with minimal image size
# =============================================================================

# -----------------------------------------------------------------------------
# STAGE 1: Dependencies
# Installs production dependencies only
# -----------------------------------------------------------------------------
FROM node:18-slim AS dependencies

WORKDIR /app

# Copy package files
COPY server/package*.json ./

# Install production dependencies only
# Uses npm ci for faster, reliable, reproducible builds
RUN npm ci --only=production --no-audit --no-fund && \
    npm cache clean --force

# -----------------------------------------------------------------------------
# STAGE 2: Builder
# Compiles TypeScript to JavaScript
# -----------------------------------------------------------------------------
FROM node:18-slim AS builder

WORKDIR /app

# Copy package files and install ALL dependencies (including devDependencies)
COPY server/package*.json ./
COPY server/tsconfig.json ./

RUN npm ci --no-audit --no-fund && \
    npm cache clean --force

# Copy source code
COPY server/src/ ./src/

# Build TypeScript
RUN npx tsc --build

# -----------------------------------------------------------------------------
# STAGE 3: Runtime
# Minimal production image with Chrome, ffmpeg, and non-root user
# -----------------------------------------------------------------------------
FROM node:18-slim AS runtime

# Install system dependencies required for Puppeteer, Chrome, and ffmpeg
# Combined in single RUN to reduce layers
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Chrome dependencies
    gnupg \
    wget \
    ca-certificates \
    fonts-liberation \
    libasound2 \
    libatk-bridge2.0-0 \
    libatk1.0-0 \
    libcups2 \
    libdbus-1-3 \
    libdrm2 \
    libgbm1 \
    libgtk-3-0 \
    libnspr4 \
    libnss3 \
    libxcomposite1 \
    libxdamage1 \
    libxrandr2 \
    xdg-utils \
    # Audio/video processing
    ffmpeg \
    # Additional libraries for Puppeteer
    libxss1 \
    libgconf-2-4 \
    libx11-xcb1 \
    libxcb-dri3-0 \
    libdrm-intel1 \
    libu2f-udev \
    libvulkan1 \
    # Cleanup
    && wget -q -O - https://dl.google.com/linux/linux_signing_key.pub | gpg --dearmor -o /usr/share/keyrings/google-chrome.gpg \
    && echo "deb [arch=amd64 signed-by=/usr/share/keyrings/google-chrome.gpg] http://dl.google.com/linux/chrome/deb/ stable main" > /etc/apt/sources.list.d/google-chrome.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends google-chrome-stable \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* /tmp/* /var/tmp/*

# Create non-root user for security
RUN groupadd -r voicecommand -g 1000 && \
    useradd -r -u 1000 -g voicecommand -d /app -s /sbin/nologin voicecommand

# Set working directory
WORKDIR /app

# Copy production dependencies from dependencies stage
COPY --from=dependencies --chown=voicecommand:voicecommand /app/node_modules ./node_modules
COPY --from=dependencies --chown=voicecommand:voicecommand /app/package*.json ./

# Copy compiled JavaScript from builder stage
COPY --from=builder --chown=voicecommand:voicecommand /app/dist ./dist

# Create required directories with correct permissions
RUN mkdir -p uploads logs wa-session linkedin-session data && \
    chown -R voicecommand:voicecommand /app

# Switch to non-root user
USER voicecommand

# Environment variables
ENV NODE_ENV=production \
    PORT=3000 \
    PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome \
    PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true \
    PUPPETEER_ARGS=--no-sandbox,--disable-setuid-sandbox,--disable-dev-shm-usage \
    WHISPER_MODEL=tiny

# Expose port
EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD node -e "require('http').get('http://localhost:3000/api/health', (r) => r.statusCode === 200 ? process.exit(0) : process.exit(1))"

# Start application
CMD ["node", "dist/index.js"]
