# Server Environment Variables
PORT=3000
MONGO_URI=mongodb://localhost:27017/voicecommand

# LLM Provider: set GROQ_API_KEY for cloud, leave empty for local Ollama
GROQ_API_KEY=

# Ollama (only needed if no GROQ_API_KEY)
OLLAMA_URL=http://localhost:11434

# LinkedIn Session Encryption (REQUIRED for encrypted cookie storage)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes for AES-256-GCM)
LINKEDIN_ENCRYPTION_KEY=

# LinkedIn Workspace ID (optional, defaults to 'default' for single-user setups)
LINKEDIN_WORKSPACE_ID=default

# Docker/Production — auto-set by Railway
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/google-chrome
# NODE_ENV=production

# SerpAPI — web search for enrichment (get key at serpapi.com)
SERPAPI_KEY=your_serpapi_key_here
